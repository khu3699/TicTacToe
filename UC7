#include <iostream>
#include <cstdlib>
#include <ctime>
using namespace std;

void computerMove(char board[])
{
    int pos;
    
    while (true)
    {
        pos = rand() % 9; // generates 0–8
        
        if (board[pos] == ' ') // check if empty
        {
            board[pos] = 'O'; // computer move
            break;
        }
    }
}
