bool checkWin(char board[])
{
    int win[8][3] = {
        {0,1,2}, {3,4,5}, {6,7,8}, // rows
        {0,3,6}, {1,4,7}, {2,5,8}, // columns
        {0,4,8}, {2,4,6}           // diagonals
    };

    for(int i = 0; i < 8; i++)
    {
        if(board[win[i][0]] != ' ' &&
           board[win[i][0]] == board[win[i][1]] &&
           board[win[i][1]] == board[win[i][2]])
        {
            return true;
        }
    }
    return false;
}
